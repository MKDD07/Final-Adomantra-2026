                start: "top top",
                end: "bottom",
                scrub: 0.2,
            },
        });
        ab2.to(".year-since", {
            right: "0",
            ease: "power1.inOut",
            delay: 0.15,
            duration: 0.75,
        });
        ab2.to([".about-area-2 .text-wrapper", ".about-area-2 .btn-wrapper"], {
            x: "100",
            opacity: 0,
            duration: 0.25,
        }, "-=0.40");
        ab2.to(".is-fading", {
