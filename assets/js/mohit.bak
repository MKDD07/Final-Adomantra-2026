}

// Initialize GSAP MatchMedia
let mm = gsap.matchMedia();

// 1. Desktop Only Animations (min-width: 1200px)
mm.add("(min-width: 1200px)", () => {

    // --- Approach Area (Horizontal Slide) ---
    if (document.querySelectorAll(".approach-area").length > 0) {
        const boxes = document.querySelectorAll(".approach-area .approach-box");

        gsap.from(boxes, {
            x: "100%",
            duration: 1,
            stagger: 0.3,
            ease: "power2.out",
            scrollTrigger: {
                trigger: ".approach-wrapper-box",
                start: "top 100%",
                end: "bottom 40%",
                scrub: 2,
                toggleActions: "play none none reverse",
            }
        });
    }

    // --- Moving Testimonial (Stacking/Toss Effect) ---
    if (document.querySelectorAll(".moving-testimonial").length > 0) {
        const section = document.querySelector(".moving-testimonial");
        const pinElement = section.querySelector(".pin");
        const cards = section.querySelectorAll(".t-card");

        // Create the Pinning effect
        ScrollTrigger.create({
            trigger: pinElement,
            start: "top top",
            end: "bottom center",
            pin: true,
            pinSpacing: false,
            scrub: true
        });

        // Initial setup for cards
        gsap.set(cards, {
            yPercent: 50,
            y: 0.5 * window.innerHeight + 1
        });

        // Timeline for the movement and rotation
        const testimonialTl = gsap.timeline({
            scrollTrigger: {
                trigger: section,
                start: "top top",
                end: "bottom center",
                scrub: true
            }
        });

        testimonialTl.to(cards, {
            yPercent: -50,
            y: -0.5 * window.innerHeight,
            duration: 1,
            stagger: -0.12,
            ease: CustomEase.create("custom", "M0,0 C0,0 0.098,0.613 0.5,0.5 0.899,0.386 1,1 1,1")
        }, "sameStep")
            .to(cards, {
                rotation: () => 20 * (Math.random() - 0.5),
                stagger: -0.12,
                duration: 0.5,
                ease: "power3.out"
            }, "sameStep")
            .to(cards, {
                rotation: 0,
                stagger: -0.12,
                duration: 0.5,
                ease: "power3.in"
            }, "sameStep+=0.5");
    }
});

// 2. Global Interactions (Works on all screen sizes)
$(document).ready(function () {
    // --- Capability Hover Effect ---
    if ($(".capability-hover-active").length > 0) {
        $('.capability-hover-active .capability-box').on("mouseover", function () {
            $(this).addClass('active').siblings().removeClass('active');
        });
    }
});
document.addEventListener("DOMContentLoaded", function () {
    const announcementBar = document.querySelector(".announcement-bar-wrapper");
    const header = document.querySelector(".header-area-2");
    let lastScrollTop = 0;

    function getAnnouncementHeight() {
        return announcementBar ? announcementBar.offsetHeight : 0;
    }

    function getAnnouncementVisible() {
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        const announcementHeight = getAnnouncementHeight();
        // How much of the announcement bar is still visible
        return Math.max(0, announcementHeight - scrollTop);
    }

    function updateHeader() {
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        const announcementHeight = getAnnouncementHeight();

        if (scrollTop <= 0) {
            // ✅ At very top — sit just below announcement bar
            header.style.top = announcementHeight + "px";
            header.style.transform = "translateY(0)";
        } else if (scrollTop < announcementHeight) {
            // ✅ Partially scrolled — follow announcement bar up
            header.style.top = (announcementHeight - scrollTop) + "px";
            header.style.transform = "translateY(0)";
        } else {
            // ✅ Announcement bar fully scrolled past — header sticks at top (0px)
            header.style.top = "0px";

            if (scrollTop > lastScrollTop) {
                // Scrolling down — hide header
                header.style.transform = "translateY(-120%)";
            } else {
                // Scrolling up — show header
                header.style.transform = "translateY(0)";
            }
        }

        lastScrollTop = scrollTop <= 0 ? 0 : scrollTop;
    }

    // Run on load and resize
    updateHeader();
    window.addEventListener("resize", updateHeader);
    window.addEventListener("scroll", updateHeader);
});

(function () {
    var funfactSwiper = null;

    function initFunfactSwiper() {
        if (window.innerWidth < 768) {
            if (!funfactSwiper) {
                funfactSwiper = new Swiper('.funfact-swiper', {
                    effect: 'cards',
                    grabCursor: true,
                    centeredSlides: true,
                    autoplay: {
                        delay: 2000,
                        disableOnInteraction: false,
                    },
                    loop: false,
                    cardsEffect: {
                        perSlideOffset: 9,
                        perSlideRotate: 3,
                        rotate: true,
                        slideShadows: false,
                    },
                });
            }
        } else {
            if (funfactSwiper) {
                funfactSwiper.destroy(true, true);
                funfactSwiper = null;
            }
        }
    }

    document.addEventListener('DOMContentLoaded', initFunfactSwiper);
    window.addEventListener('resize', initFunfactSwiper);
})();
/* ── Gallery GSAP Flip ── */
document.addEventListener('DOMContentLoaded', function () {
    var gallerySection = document.getElementById('gallery-card');
    if (!gallerySection) return;

    gsap.registerPlugin(Flip);

    // ScrollSmoother uses #smooth-content as the scroller
    var scroller = document.getElementById('smooth-content') || window;

    let flipCtx;

    function createTween() {
        var galleryElement = document.getElementById('gallery-card');
        var galleryItems = galleryElement.querySelectorAll('.gallery__item');

        if (flipCtx) { flipCtx.revert(); flipCtx = null; }
        galleryElement.classList.remove('gallery--final');

        flipCtx = gsap.context(function () {
            // Capture "final" positions while class is on
            galleryElement.classList.add('gallery--final');
            var flipState = Flip.getState(galleryItems);
            galleryElement.classList.remove('gallery--final');

            var flip = Flip.to(flipState, {
                simple: true,
                ease: 'expoScale(1, 5)'
            });

            var tl = gsap.timeline({
                scrollTrigger: {
                    trigger: galleryElement.parentNode,  /* .gallery-wrap */
                    scroller: scroller,
                    start: 'top top',
                    end: '+=150%',
                    scrub: 1.2,
                    pin: true,
                    anticipatePin: 1,
                    invalidateOnRefresh: true
                }
            });
            tl.add(flip);

            return function () { gsap.set(galleryItems, { clearProps: 'all' }); };
        });
    }

    // Wait for ScrollSmoother to init first, then build the tween
    setTimeout(createTween, 300);

    var resizeTimer;
    window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(createTween, 250);
    });
});
console.clear();

gsap.registerPlugin(ScrollTrigger);
gsap.registerPlugin(Flip);

let flipCtx;

const createTween = () => {
    let galleryElement = document.querySelector("#gallery-8");

    if (!galleryElement) return;

    let galleryItems = galleryElement.querySelectorAll(".gallery__item");

    console.log(flipCtx);

    flipCtx && flipCtx.revert();
    galleryElement.classList.remove("gallery--final");

    flipCtx = gsap.context(() => {
        // Temporarily add the final class to capture the final state
        galleryElement.classList.add("gallery--final");
        const flipState = Flip.getState(galleryItems);
        galleryElement.classList.remove("gallery--final");

        const flip = Flip.to(flipState, {
            simple: true,
            ease: "expoScale(1, 3)"
        });

        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: galleryElement.parentNode,
                start: "center center",
                end: "+=200%",
                scrub: 1.2,
                pin: galleryElement.parentNode,
                anticipatePin: 1
                // markers: true
            }
        });
        tl.add(flip);

        // Add opacity cross-fade for the logo
        tl.to(".logo-normal", { opacity: 0 }, 0);
        tl.to(".logo-fade", { opacity: 1 }, 0);
        return () => gsap.set(galleryItems, { clearProps: "all" });
    });
};
createTween();

window.addEventListener("resize", createTween);

// --- 8. Sync Hero Height with Video ---
function syncHeroHeight() {
    const $hero = $(".hero-section-3__area");
    const $video = $hero.find(".bg-video");

    if ($hero.length && $video.length) {
        const video = $video[0];

        const updateHeight = () => {
            const containerWidth = $hero.outerWidth();
            const videoWidth = video.videoWidth;
            const videoHeight = video.videoHeight;

            if (videoWidth && videoHeight) {
                const ratio = videoHeight / videoWidth;
                const calculatedHeight = Math.floor(containerWidth * ratio);
                $hero.css("min-height", calculatedHeight + "px");
                console.log("Hero height synced to video aspect ratio:", calculatedHeight);
            }
        };

        if (video.readyState >= 1) {
            updateHeight();
        }

        video.addEventListener("loadedmetadata", updateHeight);
        window.addEventListener("resize", updateHeight);

        // Multiple fallbacks for dynamic content loading
        setTimeout(updateHeight, 500);
        setTimeout(updateHeight, 2000);
    }
}

$(document).ready(function () {
    syncHeroHeight();
});
function syncHeroHeight() {
    const video = document.querySelector(".bg-video");
    const wrapper = document.querySelector(".hero-section-3__wrapper");

    if (!video || !wrapper) return;

    const height = video.offsetHeight;
    wrapper.style.minHeight = height + "px";
}

// run on load
window.addEventListener("load", syncHeroHeight);

// run on resize
window.addEventListener("resize", syncHeroHeight);
// parallax
if (document.querySelectorAll(".parallax-slider-wrapper").length > 0) {
    const selectAll = (e) => document.querySelectorAll(e);
    gsap.registerPlugin(ScrollTrigger);
    const tracks = selectAll(".parallax-slider-wrapper");

    tracks.forEach((track) => {
        let trackWrapper = track.querySelectorAll(".parallax-slider");
        let allImgs = track.querySelectorAll(".image");

        let trackWrapperWidth = () => {
            let width = 0;
            trackWrapper.forEach((el) => (width += el.offsetWidth));
            return width;
        };

        gsap.defaults({ ease: "none" });
        const gap = window.innerWidth * 0.05;
        let scrollTween = gsap.to(trackWrapper, {
            x: () => -trackWrapperWidth() + window.innerWidth + gap,
            scrollTrigger: {
                trigger: track,
                pin: true,
                scrub: 3,
                start: "center center",
                end: () => "+=" + (track.scrollWidth - window.innerWidth),
                onRefresh: (self) => self.getTween().resetTo("totalProgress", 0),
                invalidateOnRefresh: true
            }
        });

        allImgs.forEach((img) => {
            gsap.fromTo(img, { transform: "translateX(-10vw)" }, {
                transform: "translateX(5vw)",
                scrollTrigger: {
                    trigger: img.parentNode,
                    containerAnimation: scrollTween,
                    start: "left right",
                    end: "right left",
                    scrub: true,
                },
            });

        });
    });
}

// works-wrapper-2 box animation start
if (document.querySelectorAll(".works-wrapper-2").length > 0) {
