`;

        $el.append(svgCode);

        const textWidth = $el.find('.r-text').outerWidth();
        $el.find('.r-underline').css({
            'width': (textWidth) + 'px',
            'display': 'block',
            'margin-top': '-5px'
        });
    });

    // --- 6. Flip Text Animation ---
    const $flipText = $(".flip-text");
    if ($flipText.length) {
        const chars = $flipText.text().split("").map(char =>
            `<span>${char === " " ? "&nbsp;" : char}</span>`
        ).join("");

        $flipText.html(chars);

        gsap.fromTo(".flip-text span",
            { rotationX: -90, opacity: 0 },
            {
                rotationX: 0,
                opacity: 1,
                duration: 0.8,
                stagger: 0.05,
                ease: "back.out(1.7)"
            }
        );
    }

    // --- 7. Case Studies Horizontal Scroll ---
    if ($(".horizontal-scroll-wrapper").length > 0) {
        const wrapper = document.querySelector(".horizontal-scroll-wrapper");

        gsap.to(wrapper, {
            x: () => {
                const w = wrapper.offsetWidth;
                const parentW = wrapper.parentElement.offsetWidth;
                return -(w - parentW);
            },
            ease: "none",
            scrollTrigger: {
                trigger: ".fun-fact-area",
                start: "top top",
                end: "bottom 0%",
                pin: true,
                scrub: 1.4,
                invalidateOnRefresh: true,
            }
        });
    }
});

// GSAP title animation
if (document.querySelectorAll(".rr_title_anim").length > 0 && typeof SplitText !== "undefined") {
    if ($('.rr_title_anim').length > 0) {
        let splitTitleLines = gsap.utils.toArray(".rr_title_anim");
        splitTitleLines.forEach(splitTextLine => {
            const tl = gsap.timeline({
                scrollTrigger: {
                    trigger: splitTextLine,
                    start: 'top 90%',
                    end: 'bottom 60%',
                    scrub: false,
                    markers: false,
                    toggleActions: 'play none none reverse'
                }
            });

            const itemSplitted = new SplitText(splitTextLine, { type: "words, lines" });
            gsap.set(splitTextLine, { perspective: 400 });
            itemSplitted.split({ type: "lines" });
            tl.from(itemSplitted.lines, {
                duration: 1,
                delay: 0.3,
                opacity: 0,
                rotationX: -80,
                force3D: true,
                transformOrigin: "top center -50",
                stagger: 0.1
            });
        });
    }
}

// --- NEW: GSAP Masked Text Reveal (Added for you) ---
if (document.querySelectorAll(".mask-text-reveal").length > 0 && typeof SplitText !== "undefined") {
    let maskLines = gsap.utils.toArray(".mask-text-reveal");
    maskLines.forEach(text => {
        // Split text into lines twice: the parent line hides the overflow, the inner line slides up
        const splitParent = new SplitText(text, { type: "lines", linesClass: "lineWrapper" });
        const splitChild = new SplitText(splitParent.lines, { type: "lines", linesClass: "lineInner" });

        // Ensure parent wrapper hides the inner line before it slides up
        gsap.set(splitParent.lines, { overflow: "hidden" });

        gsap.from(splitChild.lines, {
            yPercent: 100,
            opacity: 0,
            duration: 1.2,
            stagger: 0.1,
            ease: "expo.out",
            scrollTrigger: {
                trigger: text,
                start: "top 85%",
                toggleActions: "play none none reverse"
            }
        });
    });
}
if (document.querySelectorAll(".funfact-area-2").length > 0) {
    gsap.to(".funfact-area-2 .thumb img", {
        scale: "1",
        scrollTrigger: {
            trigger: ".funfact-area-2 .thumb",
            start: "top top",
            end: "70% top",
            pin: true,
            scrub: 2,
        }
    })
}


if (document.querySelectorAll(".approach-area-container").length > 0) {
