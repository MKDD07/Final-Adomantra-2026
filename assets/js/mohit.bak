mm.add("(min-width: 1400px)", () => {

    if (document.querySelectorAll(".about-area-2").length > 0) {
        var ab2 = gsap.timeline({
            scrollTrigger: {
                trigger: ".about-area-2 .section-content",
                pin: ".about-area-2",
