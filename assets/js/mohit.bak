        {
            opacity: 1,
            scale: 1,
            y: 0,
            duration: 0.8,
            stagger: {
                each: 0.2,
                from: "random",
            },
            scrollTrigger: {
                trigger: ".works-wrapper-2",
                start: "top bottom",
                end: "bottom top",
                scrub: false,
            },
        }
    );
}
