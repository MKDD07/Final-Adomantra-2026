$(document).ready(function () {
    // --- 1. GSAP Text Reveal ---
    if (typeof SplitText !== "undefined") {
        $('.split-text-reveal').each(function () {
            const $item = $(this);
            const split = new SplitText(this, { type: "words,chars" });

            gsap.from(split.chars, {
                opacity: 0.1,
                y: 10,
                stagger: 0.05,
                duration: 1,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: this,
                    start: "top 90%",
                    end: "top 50%",
                    scrub: 1,
                }
            });
        });
    }
    window.addEventListener("load", () => {

        // LEFT → move from left
        gsap.from(".rr-text-move.left", {
            x: -40,
            opacity: 1,
            duration: 0.8,
            ease: "power2.out",
            stagger: 0.1
        });

        // RIGHT → move from right
        gsap.from(".rr-text-move.right", {
            x: 40,
            opacity: 1,
            duration: 0.8,
            ease: "power2.out",
            stagger: 0.1
        });

    });
    // --- 2. Service Area Image Growth ---
    const $serviceBoxes = $('.service-box');
    if ($serviceBoxes.length > 0 && typeof gsap !== "undefined") {
        $serviceBoxes.each(function () {
            const $thumb = $(this).find('.thumb');
            if ($thumb.length && window.innerWidth > 991) {
                gsap.to($thumb[0], {
                    width: "600px",
                    ease: "none",
                    scrollTrigger: {
                        trigger: this,
                        start: "top 80%",
                        end: "bottom 20%",
                        scrub: 1,
                    }
                });
            }
        });
    }

    // --- 3. Funfact Pinning & Fade ---
    const $pinArea = $('.pin-area');
    const $pinElement = $('.pin-element');
    if ($pinArea.length && $pinElement.length && typeof gsap !== "undefined") {
        let mm = gsap.matchMedia();
        mm.add("(min-width: 992px)", () => {
            ScrollTrigger.create({
                trigger: $pinArea[0],
                start: "top 120px",
                end: "bottom bottom",
                pin: $pinElement[0],
                pinSpacing: false,
            });

            $('.funfact-item').each(function () {
                gsap.to(this, {
                    opacity: 1,
                    scrollTrigger: {
                        trigger: this,
                        start: "top 80%",
                        end: "top 40%",
                        scrub: true,
                    }
                });
            });
        });
    }

    // --- 4. Matter.js Physics Container ---
    const $container = $('#gravity-container');
    const $items = $('[data-t-throwable-el]');

    if ($container.length && $items.length && typeof Matter !== "undefined") {
        const { Engine, Bodies, Composite, Mouse, MouseConstraint } = Matter;

        $container.css({ position: 'relative', overflow: 'hidden' });
        const W = $container.outerWidth();
        const H = $container.outerHeight();

        const engine = Engine.create();
        const world = engine.world;

        const ground = Bodies.rectangle(W / 2, H + 50, W, 100, { isStatic: true });
        const leftWall = Bodies.rectangle(-50, H / 2, 100, H, { isStatic: true });
        const rightWall = Bodies.rectangle(W + 50, H / 2, 100, H, { isStatic: true });
        const ceiling = Bodies.rectangle(W / 2, -100, W, 100, { isStatic: true });

        Composite.add(world, [ground, leftWall, rightWall, ceiling]);

        const itemBodies = $items.map(function () {
            const $el = $(this);
            const width = $el.outerWidth();
            const height = $el.outerHeight();

            $el.css({ position: 'absolute', top: 0, left: 0, margin: 0 });

            const x = Math.random() * (W - width) + width / 2;
            const y = Math.random() * -800 - height;

            const body = Bodies.rectangle(x, y, width, height, {
                restitution: 0.5,
                friction: 0.1,
                chamfer: { radius: height / 2 }
            });

            return { body, element: $el[0], width, height };
        }).get();

        Composite.add(world, itemBodies.map(ib => ib.body));

        const mouse = Mouse.create($container[0]);
        const syncMouse = () => {
            const r = $container[0].getBoundingClientRect();
            mouse.offset.x = r.left + window.scrollX;
            mouse.offset.y = r.top + window.scrollY;
        };

        $(window).on('scroll resize', syncMouse);

        Composite.add(world, MouseConstraint.create(engine, {
            mouse: mouse,
            constraint: { stiffness: 0.5, render: { visible: false } }
        }));

        (function run() {
            itemBodies.forEach(({ body, element, width, height }) => {
                const { x, y } = body.position;
                $(element).css('transform', `translate(${x - width / 2}px, ${y - height / 2}px) rotate(${body.angle}rad)`);
            });
            Engine.update(engine, 1000 / 60);
            requestAnimationFrame(run);
        })();
    }

    // --- 5. Dynamic SVG Underline for <r> tags ---
    const rPalette = [
        'clr-sunset', 'clr-ocean', 'clr-lime', 'clr-purple', 'clr-pink',
        'clr-gold', 'clr-ice', 'clr-fire', 'clr-sky', 'clr-neon'
    ];

    $('r').each(function () {
        const $el = $(this);

        // Check if there's already a span (possibly with color classes)
        let $innerSpan = $el.find('span');

        if ($innerSpan.length === 0) {
            const text = $el.text();
            const randomColor = rPalette[Math.floor(Math.random() * rPalette.length)];
            $el.html(`<span class="r-text ${randomColor}">${text}</span>`);
            $innerSpan = $el.find('.r-text');
        } else {
            $innerSpan.addClass('r-text');
            const hasColor = rPalette.some(cls => $innerSpan.hasClass(cls));
            if (!hasColor) {
                const randomColor = rPalette[Math.floor(Math.random() * rPalette.length)];
                $innerSpan.addClass(randomColor);
            }
        }

        // Determine which color class is active to apply to SVG as well
        let activeColor = "";
        rPalette.forEach(cls => {
            if ($innerSpan.hasClass(cls)) activeColor = cls;
        });

        // Create SVG Element
        const svgCode = `
          <svg class="r-underline ${activeColor}" width="159" height="5" viewBox="0 0 159 5" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
