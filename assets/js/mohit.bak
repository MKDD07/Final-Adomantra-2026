            duration: 0.15,
        });
        ab2.to(".year-since .last-text", {
            fontSize: 30,
            lineHeight: "27px",
            letterSpacing: "-0.1em",
            position: "absolute",
            top: 0,
            right: 0,
            ease: "none",
            duration: 0.40,
        });
